{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZCode Reader",
  "version": "0.1.0",
  "identifier": "com.me.zcode-reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:4310",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZCode",
        "width": 1200,
        "height": 800,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
